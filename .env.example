# Linear API Configuration
# Copy this file to .env and fill in your values

# Default: no env vars required. Run `lnr auth login` to sign in through
# browser-based OAuth with Dynamic Client Registration.

# Optional: OAuth scopes for DCR sign-in
# LINEAR_OAUTH_SCOPES="read write"

# Optional: existing OAuth access token, if you already have one
# LINEAR_OAUTH_ACCESS_TOKEN=your-oauth-access-token

# Optional: Linear Personal API Key. Takes precedence over OAuth.
# Get it from: Linear Settings → API → Personal API keys
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxx

# Your Linear Team ID (UUID format)
# Find it in your team URL: linear.app/team/TEAM_ID/...
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Default project ID if you want tickets to go to a specific project
# LINEAR_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Default assignee ID (your user ID)
# LINEAR_ASSIGNEE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
